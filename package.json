{
  "name": "testing-os",
  "version": "0.1.0-pre",
  "private": true,
  "description": "Operating system for testing in the AI era — protocols, evidence stores, and learning loops for AI-assisted software.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "tsc --build --clean",
    "test": "vitest run --passWithNoTests",
    "verify": "npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dogfood-lab/testing-os.git"
  },
  "homepage": "https://github.com/dogfood-lab/testing-os",
  "bugs": {
    "url": "https://github.com/dogfood-lab/testing-os/issues"
  },
  "author": "mcp-tool-shop",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
